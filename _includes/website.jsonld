{
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebSite",
            "@id": "{{ site.url }}/#website",
            "name": "{{ site.title }}",
            "description": "{{ site.description }}",
            "url": "{{ site.url }}",
            "isAccessibleForFree": true
        },
        {
            "@type": "Organization",
            "@id": "{{ site.url }}/#organization",
            "name": "{{ site.org-name }}",
            "url": "{{ site.url }}",
            "logo": "{{ site.url }}/assets/img/avatar.png"
        }
    ]
}
