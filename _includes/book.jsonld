{
    "@context": "https://schema.org",
    "@type": "Book",
    "name": "{{ page.title }}",
    "description": "{{ page.description | default: site.description }}",
    "url": "{{ site.url }}{{ page.url }}",
    "isAccessibleForFree": true,
    "datePublished": "{{ page.date | date_to_xmlschema }}",
    "author": [
        {% for a in page.author %}
            {"@type": "Person", "name": "{{ a }}"}{% unless forloop.last %},{% endunless %}
        {% else %}
            {"@type": "Organization", "name": "{{ site.author }}"}
        {% endfor %}
    ],
    "image": ["{{ site.url }}/assets/img/avatar-og.png"],
    "publisher": {
        "@type": "Organization",
        "name": "{{ site.title }}",
        "url": "{{ site.url }}"
    }
}
