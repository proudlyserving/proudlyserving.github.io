{
    "@context": "http://schema.org",
    "@type": "{{ page.schematype }}",
    "mainEntity": {
        "@type": "Person",
        "name": "{{ page.title }}",
        "alternateName": "{{ page.firstName}}",
        "description": "{{ page.description}}",
        "image": "{{ site.url }}/assets/img/{{ page.img-path }}/{{ page.img-feat }}",
        "url": "{{ page.website }}",
        "sameAs": "{{ page.linkedin }}"
    }
}