{
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "mainEntity": {
        "@type": "Person",
        "name": "{{ page.title }}",
        "description": "{{ page.description | default: site.description }}",
        "image": "{{ site.url }}/assets/img/{{ page.img-path }}/{{ page.img-feat }}",
        {% if page.jobTitle %}"jobTitle": "{{ page.jobTitle }}",{% endif %}
        {% if page.org %}"worksFor": {"@type": "Organization", "name": "{{ page.org }}"},{% endif %}
        "sameAs": [
            {% if page.website %}"{{ page.website }}"{% endif %}
            {% if page.website and page.linkedin %},{% endif %}
            {% if page.linkedin %}"{{ page.linkedin }}"{% endif %}
        ]
    }
}
