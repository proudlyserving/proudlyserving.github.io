{
    "@context": "https://schema.org",
    "@type": "{{ page.schematype }}",
    "headline": "{{ page.title }}",
    "description": "{{ page.description | default: site.description }}",
    "url": "{{ site.url }}{{ page.url }}",
    "isAccessibleForFree": true,
    "datePublished": "{{ page.date | date_to_xmlschema }}",
    "author": [
        {% for a in page.author %}
            {"@type": "Person", "name": "{{ a }}"}{% unless forloop.last %},{% endunless %}
        {% else %}
            {"@type": "Organization", "name": "{{ site.author }}"}
        {% endfor %}
    ],
    "image": ["{{ site.url }}/assets/img/avatar-og.png"],
    "publisher": {
        "@type": "Organization",
        "name": "{{ site.title }}",
        "url": "{{ site.url }}"
    },
    "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": "{{ site.title }}",
                "item": "{{ site.url }}"
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "{{ site.contents-name }}",
                "item": "{{ site.url }}{{ site.contents-url }}"
            },
            {
                "@type": "ListItem",
                "position": 3,
                "name": "{{ page.title }}",
                "item": "{{ site.url }}{{ page.url }}"
            }
        ]
    }
}
